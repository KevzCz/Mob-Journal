	"authors": [
		"KevzCz",
		"PixelDreamStudios"
	],
	"contact": {
		"homepage": "https://www.curseforge.com/minecraft/mc-mods/mob-journal",
		"sources": "https://github.com/KevzCz/Mob-Journal",
		"issues": "https://github.com/KevzCz/Mob-Journal/issues"
	},
	"license": "MIT",
	"icon": "assets/journal/icon.png",
